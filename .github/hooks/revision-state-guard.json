{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "pwsh -File tools/revision-state-guard.ps1",
        "windows": "powershell -ExecutionPolicy Bypass -File tools\\revision-state-guard.ps1",
        "cwd": ".",
        "timeout": 10
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "pwsh -File tools/revision-state-guard.ps1",
        "windows": "powershell -ExecutionPolicy Bypass -File tools\\revision-state-guard.ps1",
        "cwd": ".",
        "timeout": 15
      }
    ]
  }
}