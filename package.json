{
  "name": "@williamduong/kb",
  "version": "1.8.1",
  "description": "CLI for installing and maintaining the Project Knowledge Base Template.",
  "private": false,
  "license": "AGPL-3.0-only",
  "author": "William Duong (Dương Tấn Nghĩa) <duongtannghia@gmail.com>",
  "homepage": "https://github.com/williamduong/project-knowledge-base-template",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/williamduong/project-knowledge-base-template.git"
  },
  "bin": {
    "kb": "bin/kb.js"
  },
  "preferGlobal": true,
  "files": [
    "bin",
    "src",
    ".github/copilot-instructions.md",
    ".github/pull_request_template.md",
    ".github/hooks",
    ".github/workflows",
    "template",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "help": "node ./bin/kb.js help",
    "start": "node ./bin/kb.js help",
    "docs:tree": "node ./tools/build-docs-tree.js",
    "release:notes": "node ./bin/kb.js release notes",
    "release:notes:legacy": "node ./tools/generate-template-changelog.js",
    "doc:gate": "node ./scripts/doc-gate.js",
    "version:sync": "node ./tools/sync-versions.js",
    "version:check": "node ./tools/sync-versions.js --check",
    "doctor": "node ./bin/kb.js doctor",
    "doctor:json": "node ./bin/kb.js doctor --json",
    "test:all": "node ./bin/kb.js test --all",
    "test:unit": "node --test \"test/**/*.test.js\"",
    "maintain": "node ./bin/kb.js maintain",
    "maintain:fast": "node ./bin/kb.js maintain --fast",
    "pack:smoke": "node ./tools/pack-smoke.js",
    "prepublishOnly": "npm run version:check && npm run doc:gate",
    "release:dry": "npm run version:check && npm run doc:gate && npm run doctor && npm run pack:smoke"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "graphology": "^0.26.0",
    "graphology-traversal": "^0.3.1",
    "js-yaml": "^4.1.1",
    "minimatch": "^10.2.5"
  }
}
