{
  "name": "@williamduong/kbx",
  "version": "2.7.0-beta.2",
  "description": "CLI for installing and maintaining the Project Knowledge Base Template.",
  "keywords": [
    "knowledge-base",
    "documentation",
    "project-documentation",
    "engineering-docs",
    "developer-tools",
    "cli",
    "template",
    "governance",
    "ai",
    "ai-agents",
    "copilot",
    "cursor",
    "claude",
    "knowledge-management",
    "release-notes",
    "change-management",
    "impact-analysis",
    "git",
    "node",
    "devops"
  ],
  "private": false,
  "license": "AGPL-3.0-only",
  "author": "William Duong <duongtannghia@gmail.com> (Dương Tấn Nghĩa)",
  "homepage": "https://github.com/williamduong/project-knowledge-base-template",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/williamduong/project-knowledge-base-template.git"
  },
  "bin": {
    "kbx": "bin/kbx.js"
  },
  "preferGlobal": true,
  "files": [
    "bin",
    "src",
    ".github/copilot-instructions.md",
    ".github/pull_request_template.md",
    ".github/hooks",
    ".github/workflows",
    "template",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "help": "node ./bin/kbx.js help",
    "start": "node ./bin/kbx.js help",
    "docs:tree": "node ./tools/build-docs-tree.js",
    "release:notes": "node ./bin/kbx.js release notes",
    "keywords:show": "node ./tools/npm-keywords.js",
    "keywords:apply": "node ./tools/npm-keywords.js --apply",
    "tag:latest": "node ./tools/npm-dist-tag.js latest",
    "tag:next": "node ./tools/npm-dist-tag.js next",
    "tag:beta": "node ./tools/npm-dist-tag.js beta",
    "tag:remove": "node ./tools/npm-dist-tag.js --remove",
    "tag:list": "npm dist-tag ls @williamduong/kbx",
    "release:notes:legacy": "node ./tools/generate-template-changelog.js",
    "doc:gate": "node ./scripts/doc-gate.js",
    "prepublish:version-guard": "node ./tools/prepublish-version-guard.js",
    "version:sync": "node ./tools/sync-versions.js",
    "version:check": "node ./tools/sync-versions.js --check",
    "doctor": "node ./bin/kbx.js doctor",
    "doctor:json": "node ./bin/kbx.js doctor --json",
    "test:all": "node ./bin/kbx.js test --all",
    "test:unit": "node --test \"test/**/*.test.js\"",
    "maintain": "node ./bin/kbx.js maintain",
    "maintain:fast": "node ./bin/kbx.js maintain --fast",
    "orch:help": "node ./tools/kb-orch.js --help",
    "orch:run": "node ./tools/kb-orch.js run",
    "pack:smoke": "node ./tools/pack-smoke.js",
    "prepublishOnly": "npm run prepublish:version-guard && npm run version:check && npm run doc:gate",
    "release:dry": "npm run prepublish:version-guard && npm run version:check && npm run doc:gate && npm run doctor && npm run pack:smoke"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "graphology": "^0.26.0",
    "graphology-traversal": "^0.3.1",
    "js-yaml": "^4.1.1",
    "minimatch": "^10.2.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@williamduong/kb": "^2.3.6"
  },
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/williamduong/project-knowledge-base-template/issues"
  }
}
